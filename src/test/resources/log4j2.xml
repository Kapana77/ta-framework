<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

  <Properties>
    <!-- Log format: timestamp | level | class | message -->
    <Property name="LOG_PATTERN">
      %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n
    </Property>
    <Property name="LOG_DIR">logs</Property>
  </Properties>

  <Appenders>

    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="${LOG_PATTERN}"/>
    </Console>

    <RollingFile name="DailyFile"
      fileName="${LOG_DIR}/test-automation.log"
      filePattern="${LOG_DIR}/test-automation-%d{yyyy-MM-dd}.log.gz">
      <PatternLayout pattern="${LOG_PATTERN}"/>
      <Policies>
        <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
      </Policies>
      <DefaultRolloverStrategy max="30"/>
    </RollingFile>

  </Appenders>

  <Loggers>
    <Logger name="epam.training" level="DEBUG" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="DailyFile"/>
    </Logger>

    <Logger name="org.openqa.selenium" level="WARN" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="DailyFile"/>
    </Logger>

    <Root level="INFO">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="DailyFile"/>
    </Root>
  </Loggers>

</Configuration>